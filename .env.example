# Frontend Runtime (Vite)
# Public variables used by the frontend build/runtime.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_GOOGLE_MAPS_API_KEY=

# Supabase Edge Functions
# Core Supabase credentials used by Deno Edge Functions.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Providers
# API keys and model controls for AI-powered features.
GOOGLE_GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CV=
AI_CV_FALLBACK_ENABLED=

# Email and Notifications
# Outbound email delivery for invitations and alerts.
RESEND_API_KEY=

# External APIs
# Third-party enrichment, crawling, search, and branding services.
FIRECRAWL_API_KEY=
SERPAPI_KEY=
BRANDFETCH_API_KEY=
LOGO_DEV_API_KEY=

# Google Cloud Services
# Credentials and project settings for Google Cloud integrations.
GOOGLE_CLOUD_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Legacy or Alternate Google Maps Key Names
# Non-standard key names are still referenced in Edge Functions.
Google_Directions_and_Geocoding_KEY=
Google_Directions/Geocoding_KEY=
